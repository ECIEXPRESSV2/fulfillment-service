# ── Base de datos (Neon, propia de Fulfillment) ──
DATABASE_URL=postgresql://USER:PASSWORD@HOST/fulfillment_db?sslmode=require&channel_binding=require

# ── Bus de eventos (RabbitMQ / CloudAMQP, compartido) ──
RABBITMQ_URL=amqps://USER:PASSWORD@HOST/VHOST
RABBITMQ_EXCHANGE=eciexpress_events
RABBITMQ_QUEUE=fulfillment_service_queue

# ── App ──
PORT=3005
NODE_ENV=development
SERVICE_NAME=fulfillment-service
TZ=America/Bogota
PUBLIC_BASE_URL=http://localhost:3005     # en producción: https://fulfillment-service-pevl.onrender.com

# ── Reglas del dominio ──
PICKUP_CODE_FALLBACK_EXPIRY_HOURS=8
SHORT_CODE_RATELIMIT_MAX=5
SHORT_CODE_RATELIMIT_WINDOW_SEC=60

# ── Outbox / reintentos ──
OUTBOX_POLL_INTERVAL_MS=5000
OUTBOX_MAX_RETRIES=5
EXPIRATION_JOB_CRON=*/1 * * * *
